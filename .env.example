# OrderOps Next.js - Environment Variables

# =========================================================
# NCB (NoCodeBackend) Configuration
# =========================================================
# Required
NCB_INSTANCE=55446_orderops_systems
NCB_API_URL=https://app.nocodebackend.com/api/user-auth
NCB_DATA_API_URL=https://app.nocodebackend.com/api/data
# Legacy alias kept for backward compatibility with older configs/routes
NCB_AUTH_API_URL=https://app.nocodebackend.com/api/user-auth
NCB_SECRET_KEY=your_ncb_secret_key_here

# =========================================================
# Public App Configuration
# =========================================================
# Required for correct public URLs in browser / redirects
NEXT_PUBLIC_APP_URL=http://localhost:3000


# =========================================================
# Email / Notifications (Unione)
# =========================================================
# Required only if email sending is used in production
UNIONE_API_KEY=your_unione_api_key_here
NOTIFICATION_SENDER_EMAIL=noreply@your-domain.com
NOTIFICATION_SENDER_NAME=OrderOps

# =========================================================
# Optional diagnostics / debug flags
# =========================================================
# Optional: enables Syrve diagnostics in frontend
# true / false
NEXT_PUBLIC_ENABLE_SYRVE_DIAGNOSTICS=false
